package {{PACKAGE_NAME}}.presentation.home

import app.cash.turbine.test
import {{PACKAGE_NAME}}.domain.usecase.GetGreetingUseCase
import io.mockk.every
import io.mockk.mockk
import kotlinx.coroutines.Dispatchers
import kotlinx.coroutines.ExperimentalCoroutinesApi
import kotlinx.coroutines.flow.flowOf
import kotlinx.coroutines.test.StandardTestDispatcher
import kotlinx.coroutines.test.resetMain
import kotlinx.coroutines.test.runTest
import kotlinx.coroutines.test.setMain
import org.junit.jupiter.api.AfterEach
import org.junit.jupiter.api.Assertions.assertEquals
import org.junit.jupiter.api.BeforeEach
import org.junit.jupiter.api.Test
import kotlin.test.assertIs

@OptIn(ExperimentalCoroutinesApi::class)
class HomeViewModelTest {

    private val testDispatcher = StandardTestDispatcher()
    private lateinit var getGreetingUseCase: GetGreetingUseCase
    private lateinit var viewModel: HomeViewModel

    @BeforeEach
    fun setup() {
        Dispatchers.setMain(testDispatcher)
        getGreetingUseCase = mockk()
    }

    @AfterEach
    fun tearDown() {
        Dispatchers.resetMain()
    }

    @Test
    fun `uiState emits success with greeting`() = runTest {
        every { getGreetingUseCase() } returns flowOf("Hello World")

        viewModel = HomeViewModel(getGreetingUseCase)

        viewModel.uiState.test {
            assertEquals(HomeUiState.Loading, awaitItem())
            val state = awaitItem()
            assertIs<HomeUiState.Success>(state)
            assertEquals("Hello World", state.greeting)
        }
    }

    @Test
    fun `uiState starts with loading`() = runTest {
        every { getGreetingUseCase() } returns flowOf("Hello World")

        viewModel = HomeViewModel(getGreetingUseCase)

        viewModel.uiState.test {
            assertEquals(HomeUiState.Loading, awaitItem())
            cancelAndIgnoreRemainingEvents()
        }
    }
}
