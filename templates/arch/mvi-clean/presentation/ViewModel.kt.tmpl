package {{PACKAGE_NAME}}.presentation.home

{{HILT_IMPORT}}
import androidx.lifecycle.ViewModel
import androidx.lifecycle.viewModelScope
import {{PACKAGE_NAME}}.domain.usecase.GetGreetingUseCase
import kotlinx.coroutines.flow.MutableStateFlow
import kotlinx.coroutines.flow.StateFlow
import kotlinx.coroutines.flow.asStateFlow
import kotlinx.coroutines.flow.catch
import kotlinx.coroutines.flow.update
import kotlinx.coroutines.launch

{{HILT_ANNOTATION}}
class HomeViewModel {{HILT_INJECT}}constructor(
    private val getGreetingUseCase: GetGreetingUseCase
) : ViewModel() {

    private val _state = MutableStateFlow(HomeState())
    val state: StateFlow<HomeState> = _state.asStateFlow()

    init {
        processIntent(HomeIntent.LoadGreeting)
    }

    fun processIntent(intent: HomeIntent) {
        when (intent) {
            is HomeIntent.LoadGreeting -> loadGreeting()
        }
    }

    private fun loadGreeting() {
        viewModelScope.launch {
            _state.update { it.copy(isLoading = true) }
            getGreetingUseCase()
                .catch { e ->
                    _state.update { it.copy(isLoading = false) }
                }
                .collect { greeting ->
                    _state.update { it.copy(greeting = greeting, isLoading = false) }
                }
        }
    }
}
