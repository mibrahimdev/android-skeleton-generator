package {{PACKAGE_NAME}}.data.repository

import {{PACKAGE_NAME}}.data.local.ItemDao
import {{PACKAGE_NAME}}.data.local.ItemEntity
import kotlinx.coroutines.flow.Flow
import kotlinx.coroutines.flow.map

data class Item(
    val id: Long = 0,
    val title: String = "",
    val description: String = ""
)

class ItemRepository(private val itemDao: ItemDao) {

    fun getItems(): Flow<List<Item>> = itemDao.getAll().map { entities ->
        entities.map { it.toDomain() }
    }

    suspend fun getItemById(id: Long): Item? = itemDao.getById(id)?.toDomain()

    suspend fun insertItem(item: Item) {
        itemDao.insert(item.toEntity())
    }

    suspend fun deleteItem(id: Long) {
        itemDao.deleteById(id)
    }
}

private fun ItemEntity.toDomain() = Item(id = id, title = title, description = description)
private fun Item.toEntity() = ItemEntity(id = id, title = title, description = description)
